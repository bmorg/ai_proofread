{
    "name": "bmorg/ai_proofread",
    "type": "typo3-cms-extension",
    "description": "AI-assisted proofreading of TYPO3 page content",
    "license": "MIT",
    "keywords": ["TYPO3", "proofreading", "AI", "LLM", "OpenRouter", "editorial"],
    "authors": [
        {
            "name": "bmorg",
            "email": "contact@bmorg.io",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^11.5 || ^12.4 || ^13.4",
        "typo3/cms-backend": "^11.5 || ^12.4 || ^13.4",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^1.7 || ^2.0",
        "psr/http-message": "^1.0 || ^2.0"
    },
    "require-dev": {
        "typo3/testing-framework": "^6.16",
        "phpunit/phpunit": "^9.6",
        "typo3/cms-fluid-styled-content": "^11.5",
        "typo3/cms-rte-ckeditor": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Bmorg\\AiProofread\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bmorg\\AiProofread\\Tests\\": "Tests/",
            "Bmorg\\AiProofread\\Build\\": "Build/Scripts/"
        }
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "process-timeout": 0
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "ai_proofread",
            "app-dir": ".Build",
            "web-dir": ".Build/public"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Bmorg\\AiProofread\\Build\\ExtensionTestLink::postAutoloadDump"
        ],
        "test:unit": ".Build/bin/phpunit -c Build/phpunit/UnitTests.xml",
        "test:functional": "typo3DatabaseDriver=pdo_sqlite .Build/bin/phpunit -c Build/phpunit/FunctionalTests.xml",
        "test": [
            "@test:unit",
            "@test:functional"
        ]
    }
}
